<%= form_with url: clients_path, method: :get, local: true, class: "mb-4" do %>
  <div class="row g-2 align-items-end">
    <div class="col-md-6">
      <%= label_tag :document, "Buscar por documento", class: "form-label" %>
      <%= text_field_tag :document, params[:document], class: "form-control" %>
    </div>
    <div class="col-md-auto">
      <%= submit_tag "Buscar", class: "btn btn-primary shadow-sm" %>
    </div>
  </div>
<% end %>

<h1>Clientes</h1>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Documento</th>
        <th>Nombre</th>
        <th>Email</th>
        <th>Estado</th>
        <th>Acción</th>
        <th>Pagos</th>
        <th>Editar</th>
      </tr>
    </thead>

    <tbody>
      <% @clients.each do |client| %>
        <tr class="<%= 'table-secondary' unless client.status %>">
          <td><%= client.document %></td>
          <td><%= client.first_name %> <%= client.last_name %></td>
          <td><%= client.email %></td>

          <td>
            <% if client.status %>
              <span class="text-success fw-bold">Activo</span>
            <% else %>
              <span class="text-danger fw-bold">Bloqueado</span>
            <% end %>
          </td>

          <td>
            <% if client.status %>
              <form action="<%= block_client_path(client) %>" method="post" style="display:inline;" onsubmit="return confirm('¿Seguro que deseas bloquear a este cliente?');">
                <input type="hidden" name="_method" value="patch">
                <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                <button type="submit" class="btn btn-outline-danger btn-sm shadow-sm">Bloquear</button>
              </form>
            <% else %>
              <form action="<%= unblock_client_path(client) %>" method="post" style="display:inline;" onsubmit="return confirm('¿Seguro que deseas desbloquear a este cliente?');">
                <input type="hidden" name="_method" value="patch">
                <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                <button type="submit" class="btn btn-outline-success btn-sm shadow-sm">Desbloquear</button>
              </form>
            <% end %>
          </td>

          <td>
            <%= link_to "Ver pagos", payments_path(client_id: client.id), class: "btn btn-info btn-sm text-white shadow-sm" %>
          </td>

          <td>
            <%= link_to "Editar", edit_client_path(client), class: "btn btn-warning btn-sm shadow-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-3">
  <%= link_to "Nuevo cliente", new_client_path, class: "btn btn-primary shadow-sm" %>
</div>