<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <h1 class="page-title mb-1">Clientes</h1>
    <p class="page-subtitle mb-0">Gestiona los clientes registrados en VirtualCoop.</p>
  </div>

  <div>
    <%= link_to "Nuevo cliente", new_client_path, class: "btn btn-primary shadow-sm px-4" %>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="stat-card stat-card-primary">
      <div>
        <p class="stat-label">Total clientes</p>
        <h3 class="stat-value"><%= @total_clients %></h3>
      </div>
      <div class="stat-icon">👥</div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="stat-card stat-card-success">
      <div>
        <p class="stat-label">Activos</p>
        <h3 class="stat-value"><%= @active_clients %></h3>
      </div>
      <div class="stat-icon">✅</div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="stat-card stat-card-danger">
      <div>
        <p class="stat-label">Bloqueados</p>
        <h3 class="stat-value"><%= @blocked_clients %></h3>
      </div>
      <div class="stat-icon">⛔</div>
    </div>
  </div>
</div>

<div class="card modern-card mb-4">
  <div class="card-body">
    <%= form_with url: clients_path, method: :get, local: true do %>
      <div class="row g-3 align-items-end">
        <div class="col-md-10">
          <%= label_tag :document, "Buscar por documento", class: "form-label fw-semibold" %>
          <%= text_field_tag :document, params[:document], class: "form-control modern-input", placeholder: "Ej: 123456789" %>
        </div>
        <div class="col-md-2 d-grid">
          <%= submit_tag "Buscar", class: "btn btn-dark shadow-sm" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="card modern-card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table modern-table align-middle mb-0">
        <thead>
          <tr>
            <th>Documento</th>
            <th>Cliente</th>
            <th>Email</th>
            <th>Estado</th>
            <th>Acción</th>
            <th>Pagos</th>
            <th>Editar</th>
          </tr>
        </thead>

        <tbody>
          <% @clients.each do |client| %>
            <tr class="<%= 'table-row-blocked' unless client.status %>">
              <td class="fw-semibold"><%= client.document %></td>

              <td>
                <div class="client-name">
                  <%= client.first_name %> <%= client.last_name %>
                </div>
              </td>

              <td>
                <span class="client-email"><%= client.email %></span>
              </td>

              <td>
                <% if client.status %>
                  <span class="status-badge status-active">Activo</span>
                <% else %>
                  <span class="status-badge status-blocked">Bloqueado</span>
                <% end %>
              </td>

              <td>
                <div class="d-flex flex-wrap gap-2">
                  <% if client.status %>
                    <form action="<%= block_client_path(client) %>" method="post" style="display:inline;" onsubmit="return confirm('¿Seguro que deseas bloquear a este cliente?');">
                      <input type="hidden" name="_method" value="patch">
                      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                      <button type="submit" class="btn btn-outline-danger btn-sm shadow-sm">Bloquear</button>
                    </form>
                  <% else %>
                    <form action="<%= unblock_client_path(client) %>" method="post" style="display:inline;" onsubmit="return confirm('¿Seguro que deseas desbloquear a este cliente?');">
                      <input type="hidden" name="_method" value="patch">
                      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                      <button type="submit" class="btn btn-outline-success btn-sm shadow-sm">Desbloquear</button>
                    </form>
                  <% end %>
                </div>
              </td>

              <td>
                <%= link_to "Ver pagos", payments_path(client_id: client.id), class: "btn btn-info btn-sm text-white shadow-sm" %>
              </td>

              <td>
                <%= link_to "Editar", edit_client_path(client), class: "btn btn-warning btn-sm shadow-sm" %>
              </td>
            </tr>
          <% end %>

          <% if @clients.empty? %>
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                No se encontraron clientes registrados.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>