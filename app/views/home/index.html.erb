<h1 class="mb-4">Dashboard</h1>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card text-white bg-primary p-3 dashboard-card">
      <h5>Total clientes</h5>
      <h3><%= @total_clients %></h3>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card text-white bg-success p-3 dashboard-card">
      <h5>Clientes activos</h5>
      <h3><%= @active_clients %></h3>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card text-white bg-danger p-3 dashboard-card">
      <h5>Clientes bloqueados</h5>
      <h3><%= @blocked_clients %></h3>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card text-white bg-dark p-3 dashboard-card">
      <h5>Total pagos</h5>
      <h3><%= @total_payments %></h3>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card text-white bg-success p-3 dashboard-card">
      <h5>Total créditos</h5>
      <p class="dashboard-amount mb-0">
        <%= number_to_currency(@total_credit, unit: "$", delimiter: ".", precision: 0) %>
      </p>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card text-white bg-danger p-3 dashboard-card">
      <h5>Total débitos</h5>
      <p class="dashboard-amount mb-0">
        <%= number_to_currency(@total_debit, unit: "$", delimiter: ".", precision: 0) %>
      </p>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card text-white bg-secondary p-3 dashboard-card">
      <h5>Balance general</h5>
      <p class="dashboard-amount mb-0">
        <%= number_to_currency(@balance, unit: "$", delimiter: ".", precision: 0) %>
      </p>
    </div>
  </div>
</div>

<h3 class="mb-3">Últimos movimientos</h3>

<div class="table-responsive mb-5">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Cliente</th>
        <th>Tipo</th>
        <th>Valor</th>
        <th>Fecha</th>
      </tr>
    </thead>
    <tbody>
      <% @recent_payments.each do |payment| %>
        <tr>
          <td><%= payment.client.full_name %></td>
          <td>
            <% if payment.payment_type.name.downcase.in?(["crédito", "credito"]) %>
              <span class="text-success fw-bold"><%= payment.payment_type.name %></span>
            <% else %>
              <span class="text-danger fw-bold"><%= payment.payment_type.name %></span>
            <% end %>
          </td>
          <td><%= number_to_currency(payment.amount, unit: "$", delimiter: ".", precision: 0) %></td>
          <td><%= payment.created_at.strftime("%d/%m/%Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<h3 class="mt-5">Resumen financiero</h3>

<div class="card p-4 mt-3 shadow-sm">
  <canvas id="paymentsChart"></canvas>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const canvas = document.getElementById("paymentsChart");
    if (!canvas) return;

    const existingChart = Chart.getChart(canvas);
    if (existingChart) existingChart.destroy();

    const ctx = canvas.getContext("2d");

    new Chart(ctx, {
      type: "bar",
      data: {
        labels: ["Créditos", "Débitos"],
        datasets: [{
          label: "Valor total",
          data: [<%= @total_credit %>, <%= @total_debit %>],
          backgroundColor: ["#198754", "#dc3545"],
          borderRadius: 10,
          borderSkipped: false
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: { beginAtZero: true }
        }
      }
    });
  });
</script>