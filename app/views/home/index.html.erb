<div class="fade-in-up">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h1 class="mb-1">Dashboard</h1>
      <p class="text-muted mb-0">Resumen general de clientes y movimientos financieros</p>
    </div>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-md-3">
      <div class="card text-white bg-primary p-4 dashboard-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-2">Total clientes</h5>
            <h3 class="mb-0"><%= @total_clients %></h3>
          </div>
          <i class="bi bi-people-fill fs-2 opacity-75"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card text-white bg-success p-4 dashboard-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-2">Clientes activos</h5>
            <h3 class="mb-0"><%= @active_clients %></h3>
          </div>
          <i class="bi bi-person-check-fill fs-2 opacity-75"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card text-white bg-danger p-4 dashboard-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-2">Clientes bloqueados</h5>
            <h3 class="mb-0"><%= @blocked_clients %></h3>
          </div>
          <i class="bi bi-person-fill-lock fs-2 opacity-75"></i>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card text-white bg-dark p-4 dashboard-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-2">Total pagos</h5>
            <h3 class="mb-0"><%= @total_payments %></h3>
          </div>
          <i class="bi bi-cash-stack fs-2 opacity-75"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <div class="col-md-4">
      <div class="card text-white bg-success p-4 dashboard-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-2">Total créditos</h5>
            <p class="dashboard-amount mb-0">
              <%= number_to_currency(@total_credit, unit: "$", delimiter: ".", separator: ",", precision: 2) %>
            </p>
          </div>
          <i class="bi bi-graph-up-arrow fs-2 opacity-75"></i>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card text-white bg-danger p-4 dashboard-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-2">Total débitos</h5>
            <p class="dashboard-amount mb-0">
              <%= number_to_currency(@total_debit, unit: "$", delimiter: ".", separator: ",", precision: 2) %>
            </p>
          </div>
          <i class="bi bi-graph-down-arrow fs-2 opacity-75"></i>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card text-white bg-secondary p-4 dashboard-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="mb-2">Balance general</h5>
            <p class="dashboard-amount mb-0">
              <%= number_to_currency(@balance, unit: "$", delimiter: ".", separator: ",", precision: 2) %>
            </p>
          </div>
          <i class="bi bi-wallet2 fs-2 opacity-75"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="table-card mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <div>
        <h3 class="mb-1">Últimos movimientos</h3>
        <p class="text-muted mb-0">Movimientos financieros registrados recientemente</p>
      </div>
    </div>

    <% if @recent_payments.any? %>
      <div class="table-responsive">
        <table class="table-modern align-middle">
          <thead>
            <tr>
              <th>Cliente</th>
              <th>Tipo</th>
              <th>Valor</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_payments.each do |payment| %>
              <% payment_type_name = payment.payment_type.name.to_s.downcase %>
              <% is_credit = payment_type_name == "crédito" || payment_type_name == "credito" %>

              <tr>
                <td class="fw-semibold"><%= payment.client.full_name %></td>
                <td>
                  <% if is_credit %>
                    <span class="badge-status badge-credit">Crédito</span>
                  <% else %>
                    <span class="badge-status badge-debit">Débito</span>
                  <% end %>
                </td>
                <td>
                  <% if is_credit %>
                    <span class="fw-bold text-success">
                      <%= number_to_currency(payment.amount, unit: "$", delimiter: ".", separator: ",", precision: 2) %>
                    </span>
                  <% else %>
                    <span class="fw-bold text-danger">
                      <%= number_to_currency(payment.amount, unit: "$", delimiter: ".", separator: ",", precision: 2) %>
                    </span>
                  <% end %>
                </td>
                <td class="text-muted"><%= payment.created_at.strftime("%d/%m/%Y") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4">
        <i class="bi bi-receipt-cutoff" style="font-size: 2rem; color: #94a3b8;"></i>
        <h5 class="mt-3 mb-1">No hay movimientos recientes</h5>
        <p class="text-muted mb-0">Cuando registres pagos, aparecerán aquí.</p>
      </div>
    <% end %>
  </div>

  <div class="table-card">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <div>
        <h3 class="mb-1">Resumen financiero</h3>
        <p class="text-muted mb-0">Comparativo entre créditos y débitos acumulados</p>
      </div>
    </div>

    <canvas id="paymentsChart"></canvas>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const canvas = document.getElementById("paymentsChart");
    if (!canvas) return;

    const existingChart = Chart.getChart(canvas);
    if (existingChart) existingChart.destroy();

    const ctx = canvas.getContext("2d");

    new Chart(ctx, {
      type: "bar",
      data: {
        labels: ["Créditos", "Débitos"],
        datasets: [{
          label: "Valor total",
          data: [<%= @total_credit %>, <%= @total_debit %>],
          backgroundColor: ["#198754", "#dc3545"],
          borderRadius: 10,
          borderSkipped: false
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(context) {
                return "$" + Number(context.raw).toLocaleString("es-CO", {
                  minimumFractionDigits: 2,
                  maximumFractionDigits: 2
                });
              }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: function(value) {
                return "$" + Number(value).toLocaleString("es-CO");
              }
            }
          }
        }
      }
    });
  });
</script>