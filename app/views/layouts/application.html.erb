<!DOCTYPE html>
<html>
  <head>
    <title>VirtualCoop</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>

  <body class="app-body">
    <button class="sidebar-toggle-btn" id="sidebarToggle">
      <i class="bi bi-list"></i>
    </button>

    <div class="app-shell">
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-top">
          <div class="brand">
            <div class="brand-logo-image">
              <%= image_tag "virtualcoop_logo.png", alt: "Logo VirtualCoop", class: "logo-img" %>
            </div>
            <div class="brand-text">
              <h4>VirtualCoop</h4>
              <p>Gestión financiera</p>
            </div>
          </div>

          <nav class="sidebar-nav">
            <%= link_to root_path, class: "sidebar-link #{'active' if current_page?(root_path)}" do %>
              <span class="icon"><i class="bi bi-grid-1x2-fill"></i></span>
              <span class="label">Dashboard</span>
            <% end %>

            <%= link_to new_client_path, class: "sidebar-link #{'active' if current_page?(new_client_path)}" do %>
              <span class="icon"><i class="bi bi-person-plus-fill"></i></span>
              <span class="label">Registrar clientes</span>
            <% end %>

            <%= link_to clients_path, class: "sidebar-link #{'active' if current_page?(clients_path)}" do %>
              <span class="icon"><i class="bi bi-people-fill"></i></span>
              <span class="label">Usuarios registrados</span>
            <% end %>

            <%= link_to new_payment_path, class: "sidebar-link #{'active' if current_page?(new_payment_path)}" do %>
              <span class="icon"><i class="bi bi-cash-coin"></i></span>
              <span class="label">Registrar pagos</span>
            <% end %>

            <%= link_to payments_path, class: "sidebar-link #{'active' if current_page?(payments_path)}" do %>
              <span class="icon"><i class="bi bi-receipt-cutoff"></i></span>
              <span class="label">Lista de pagos</span>
            <% end %>
          </nav>
        </div>

        <div class="sidebar-footer">
          <%= button_to logout_path, method: :delete, class: "logout-btn" do %>
            <i class="bi bi-box-arrow-right me-2"></i>
            <span class="logout-label">Cerrar sesión</span>
          <% end %>
        </div>
      </aside>

      <main class="main-content" id="mainContent">
        <div class="topbar">
          <div>
            <h1 class="page-title">VirtualCoop</h1>
            <p class="page-subtitle">Panel de gestión financiera</p>
          </div>

          <div class="topbar-user">
            <i class="bi bi-person-circle me-2"></i>
            <span><%= current_user.email if current_user %></span>
          </div>
        </div>

        <% if notice %>
          <div class="custom-alert notice-alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <%= notice %>
          </div>
        <% end %>

        <% if alert %>
          <div class="custom-alert alert-alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <%= alert %>
          </div>
        <% end %>

        <div class="content-shell">
          <%= yield %>
        </div>
      </main>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const sidebar = document.getElementById("sidebar");
        const toggleBtn = document.getElementById("sidebarToggle");

        if (toggleBtn && sidebar) {
          toggleBtn.addEventListener("click", function () {
            sidebar.classList.toggle("collapsed");
          });

          sidebar.addEventListener("mouseenter", function () {
            if (sidebar.classList.contains("collapsed")) {
              sidebar.classList.add("hover-open");
            }
          });

          sidebar.addEventListener("mouseleave", function () {
            sidebar.classList.remove("hover-open");
          });
        }
      });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>