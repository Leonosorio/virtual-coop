<!DOCTYPE html>
<html>
  <head>
    <title>VirtualCoop - Login</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
      html, body {
        height: 100%;
        margin: 0;
      }

      body {
        min-height: 100vh;
        font-family: 'Segoe UI', sans-serif;
        background:
          radial-gradient(circle at top left, rgba(56, 189, 248, 0.18), transparent 30%),
          radial-gradient(circle at bottom right, rgba(37, 99, 235, 0.14), transparent 30%),
          linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
      }

      .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
      }

      .login-wrapper {
        width: 100%;
        max-width: 440px;
      }

      .login-card {
  background: rgba(255, 255, 255, 0.97);
  border: 1px solid #e2e8f0;
  border-radius: 24px;
  padding: 36px 30px;
  box-shadow: 0 20px 50px rgba(15, 23, 42, 0.10);
}

     .login-brand h1 {
  margin: 0;
  font-size: 2.2rem;
  font-weight: 800;
  color: #0f172a;
}

 .login-logo-box {
  width: 130px;
  height: 130px;
  margin: 0 auto 20px;
  border-radius: 28px;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.12), rgba(56, 189, 248, 0.18));
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-logo {
  width: 100px;
  height: 100px;
  object-fit: contain;
  display: block;
}

      .login-brand h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
      }

      .login-brand p {
        margin: 10px 0 0;
        color: #64748b;
        font-size: 0.98rem;
      }

      .form-label {
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 8px;
      }

      .login-input {
        min-height: 50px;
        border-radius: 14px;
        border: 1px solid #dbe2ea;
        padding: 12px 14px;
      }

      .login-input:focus {
        border-color: #60a5fa;
        box-shadow: 0 0 0 4px rgba(96, 165, 250, 0.14);
      }

      .login-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        font-size: 0.92rem;
      }

      .login-link {
        color: #2563eb;
        text-decoration: none;
        font-weight: 600;
      }

      .login-link:hover {
        text-decoration: underline;
      }

      .btn-fintech {
        border: none;
        border-radius: 14px;
        padding: 12px 18px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .btn-primary-fintech {
        background: linear-gradient(135deg, #2563eb, #38bdf8);
        color: white;
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.22);
      }

      .btn-primary-fintech:hover {
        transform: translateY(-1px);
        color: white;
      }

      .login-btn {
        min-height: 50px;
        width: 100%;
      }

      .login-footer {
        margin-top: 20px;
        text-align: center;
      }

      .login-footer p {
        margin: 0;
        color: #94a3b8;
        font-size: 0.9rem;
      }
    </style>
  </head>

  <body>
    <%= yield %>
  </body>
</html>