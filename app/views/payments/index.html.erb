<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <h1 class="page-title mb-1">Lista de pagos</h1>
    <p class="page-subtitle mb-0">Consulta y gestión de movimientos financieros.</p>
  </div>

  <div class="d-flex gap-2 flex-wrap">
    <%= link_to new_payment_path, class: "btn btn-primary shadow-sm" do %>
      <i class="bi bi-plus-circle me-1"></i>
      Nuevo pago
    <% end %>

    <%= link_to export_payments_path, class: "btn btn-success shadow-sm" do %>
      <i class="bi bi-file-earmark-excel me-1"></i>
      Exportar a Excel
    <% end %>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="stat-card stat-card-primary">
      <div>
        <p class="stat-label">Total pagos</p>
     <h3 class="stat-value"><%= @total_payments %></h3>
      </div>
      <div class="stat-icon">💳</div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="stat-card stat-card-success">
      <div>
        <p class="stat-label">Créditos</p>
<h3 class="stat-value"><%= @credit_payments %></h3>      </div>
      <div class="stat-icon">📈</div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="stat-card stat-card-danger">
      <div>
        <p class="stat-label">Débitos</p>
<h3 class="stat-value"><%= @debit_payments %></h3>      </div>
      <div class="stat-icon">📉</div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="stat-card stat-card-dark">
      <div>
        <p class="stat-label">Movimientos visibles</p>
<h3 class="stat-value"><%= @visible_movements %></h3>      </div>
      <div class="stat-icon">📋</div>
    </div>
  </div>
</div>

<div class="card modern-card mb-4">
  <div class="card-body">
    <%= form_with url: payments_path, method: :get, local: true do %>
      <div class="row g-3 align-items-end">
        <div class="col-md-4">
          <%= label_tag :client_id, "Filtrar por cliente", class: "form-label fw-semibold" %>
          <%= select_tag :client_id,
              options_from_collection_for_select(Client.order(:first_name), :id, :full_name, params[:client_id]),
              include_blank: "Todos los clientes",
              class: "form-select modern-input" %>
        </div>

        <div class="col-md-4">
          <%= label_tag :payment_kind, "Filtrar por tipo", class: "form-label fw-semibold" %>
          <%= select_tag :payment_kind,
              options_for_select([["Todos", ""], ["Crédito", "credito"], ["Débito", "debito"]], params[:payment_kind]),
              class: "form-select modern-input" %>
        </div>

        <div class="col-md-2 d-grid">
          <%= submit_tag "Filtrar", class: "btn btn-dark shadow-sm" %>
        </div>

        <div class="col-md-2 d-grid">
          <%= link_to "Limpiar", payments_path, class: "btn btn-outline-secondary shadow-sm" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="card modern-card fade-in-up">
  <div class="card-body p-0">
    <% if @payments.any? %>
      <div class="table-responsive">
        <table class="table modern-table align-middle mb-0">
          <thead>
            <tr>
              <th>Cliente</th>
              <th>Tipo de pago</th>
              <th>Número de cuenta</th>
              <th>Valor</th>
              <th>Descripción</th>
              <th>Fecha</th>
              <th class="text-center">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @payments.each do |payment| %>
              <% payment_type_name = payment.payment_type.name.to_s.downcase %>
              <% is_credit = payment_type_name == "crédito" || payment_type_name == "credito" %>

              <tr>
                <td>
                  <div class="client-name"><%= payment.client.full_name %></div>
                  <div class="client-email"><%= payment.client.email %></div>
                </td>

                <td>
                  <% if is_credit %>
                    <span class="badge-status badge-credit">Crédito</span>
                  <% else %>
                    <span class="badge-status badge-debit">Débito</span>
                  <% end %>
                </td>

                <td>
                  <span class="text-muted fw-semibold"><%= payment.client.account_number %></span>
                </td>

                <td>
                  <% if is_credit %>
                    <span class="payment-amount payment-credit">
                      <%= number_to_currency(payment.amount, unit: "$", delimiter: ".", separator: ",", precision: 2) %>
                    </span>
                  <% else %>
                    <span class="payment-amount payment-debit">
                      <%= number_to_currency(payment.amount, unit: "$", delimiter: ".", separator: ",", precision: 2) %>
                    </span>
                  <% end %>
                </td>

                <td>
                  <% if payment.description.present? %>
                    <span class="payment-description"><%= payment.description %></span>
                  <% else %>
                    <span class="text-muted fst-italic">Sin descripción</span>
                  <% end %>
                </td>

                <td>
                  <span class="text-muted"><%= payment.created_at.strftime("%d/%m/%Y %H:%M") %></span>
                </td>

                <td class="text-center">
                  <%= link_to edit_payment_path(payment), class: "btn btn-sm btn-warning shadow-sm" do %>
                    <i class="bi bi-pencil-square me-1"></i>
                    Editar
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-receipt-cutoff" style="font-size: 2rem; color: #94a3b8;"></i>
        <h5 class="mt-3 mb-1">No hay pagos registrados</h5>
        <p class="text-muted mb-3">Aún no se han registrado movimientos financieros en el sistema.</p>

        <%= link_to new_payment_path, class: "btn btn-primary shadow-sm" do %>
          <i class="bi bi-plus-circle me-1"></i>
          Registrar primer pago
        <% end %>
      </div>
    <% end %>
  </div>
</div>